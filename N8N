ÉTAPE 2 — Installer n8n local
Méthode Docker (meilleure)

Créer dossier :

mkdir C:\ai-stack
cd C:\ai-stack

Créer fichier :

docker-compose.yml

Contenu :

version: "3.9"

services:

  n8n:
    image: n8nio/n8n
    ports:
      - "5678:5678"
    environment:
      - N8N_BASIC_AUTH_ACTIVE=true
      - N8N_BASIC_AUTH_USER=admin
      - N8N_BASIC_AUTH_PASSWORD=admin123
    volumes:
      - ./n8n_data:/home/node/.n8n

  postgres:
    image: postgres
    restart: always
    environment:
      POSTGRES_USER: ai
      POSTGRES_PASSWORD: ai123
      POSTGRES_DB: aiagents
    ports:
      - "5432:5432"

  qdrant:
    image: qdrant/qdrant
    ports:
      - "6333:6333"

  ollama:
    image: ollama/ollama
    ports:
      - "11434:11434"
    volumes:
      - ./ollama:/root/.ollama

Lancer :

docker compose up -d
