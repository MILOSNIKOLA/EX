ÉTAPE 5 — Agent IA GitHub automatique
Fonctionnement

Workflow :

GitHub → Bug détecté
↓
n8n
↓
Ollama analyse
↓
Open Interpreter modifie
↓
Git commit
↓
Git push automatique
Workflow JSON prêt à importer dans n8n

Crée workflow :

{
  "name": "Auto GitHub AI Agent",
  "nodes": [
    {
      "parameters": {},
      "id": "github-trigger",
      "name": "GitHub Trigger",
      "type": "n8n-nodes-base.githubTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "jsonParameters": true,
        "options": {},
        "bodyParametersJson": "{\n  \"model\": \"deepseek-coder\",\n  \"prompt\": \"Analyse le bug et propose un correctif\"\n}"
      },
      "id": "ollama",
      "name": "Ollama Fix",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    },
    {
      "parameters": {
        "command": "git add . && git commit -m \"AI Fix\" && git push"
      },
      "id": "push",
      "name": "Push GitHub",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [800, 300]
    }
  ],
  "connections": {
    "GitHub Trigger": {
      "main": [
        [
          {
            "node": "Ollama Fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Fix": {
      "main": [
        [
          {
            "node": "Push GitHub",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
